# .env file for Podcast RAG application

# Database settings (optional, defaults are set in Docker)
# DATABASE_URL=sqlite:///./data/podcast_rag.db

# ChromaDB settings (optional, defaults are set in Docker)
# CHROMA_PERSIST_DIRECTORY=/app/data/chroma

# Model settings (optional)
# TRANSCRIPTION_MODEL=large-v3
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Frontend settings (set in Docker)
# REACT_APP_API_URL=http://backend:8000

